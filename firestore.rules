rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.membershipType == 'admin') ||
        (request.auth.token.email == 'midlajthonikkadavan01@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profile Rules
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.keys().hasAll(['displayName', 'email', 'createdAt']) &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUserProfile(incoming());
    }

    // 2. Course Progress & Enrollments
    match /users/{userId}/progress/{courseId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/enrollments/{courseId} {
      allow read, list: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // 3. Courses (Publicly readable for signed in users)
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 4. Spotlight
    match /spotlight/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
